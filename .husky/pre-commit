#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# BuildFlow Pre-commit Security Check
echo "🔍 Running pre-commit security checks..."

# Check for environment variable leaks using dotenv-linter
echo "🛡️ Checking for exposed environment variables..."
npx dotenv-linter

# Check for common secrets patterns in staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.(ts|tsx|js|jsx|json|env|yaml|yml|md)$" || true)

if [ ! -z "$STAGED_FILES" ]; then
  echo "🔐 Scanning staged files for secrets..."
  
  # Check for common secret patterns
  SECRET_PATTERNS=(
    # API Keys and Tokens
    "[aA][pP][iI][_-]?[kK][eE][yY].*[=:].*['\"][a-zA-Z0-9]{20,}['\"]"
    "[sS][eE][cC][rR][eE][tT].*[=:].*['\"][a-zA-Z0-9]{20,}['\"]"
    "[tT][oO][kK][eE][nN].*[=:].*['\"][a-zA-Z0-9]{20,}['\"]"
    "[pP][aA][sS][sS][wW][oO][rR][dD].*[=:].*['\"].{8,}['\"]"
    
    # Database URLs
    "postgresql://.*:.*@.*"
    "mysql://.*:.*@.*"
    "mongodb://.*:.*@.*"
    
    # JWT Secrets
    "[jJ][wW][tT][_-]?[sS][eE][cC][rR][eE][tT].*[=:].*['\"].{20,}['\"]"
    
    # AWS Keys
    "AKIA[0-9A-Z]{16}"
    "['\"][0-9a-zA-Z/+]{40}['\"]"
    
    # Stripe Keys
    "sk_live_[0-9a-zA-Z]{24,}"
    "pk_live_[0-9a-zA-Z]{24,}"
    
    # Other common patterns
    "['\"][a-zA-Z0-9]{32,}['\"]"
  )
  
  FOUND_SECRETS=false
  
  for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
      for pattern in "${SECRET_PATTERNS[@]}"; do
        if grep -qE "$pattern" "$file"; then
          echo "❌ Potential secret found in $file"
          echo "   Pattern: $pattern"
          grep -nE "$pattern" "$file" | head -3
          FOUND_SECRETS=true
        fi
      done
    fi
  done
  
  if [ "$FOUND_SECRETS" = true ]; then
    echo ""
    echo "🚨 SECURITY WARNING: Potential secrets detected in staged files!"
    echo "Please review the files above and remove any sensitive information."
    echo "Consider using environment variables or a secrets management system."
    echo ""
    echo "If this is a false positive, you can:"
    echo "1. Move secrets to .env files (already gitignored)"
    echo "2. Use environment variables"
    echo "3. Add '# nosecret' comment to the line to ignore this check"
    echo ""
    exit 1
  fi
fi

# Run lint-staged if it exists
if command -v npx >/dev/null 2>&1 && npx lint-staged --help >/dev/null 2>&1; then
  echo "🧹 Running lint-staged..."
  npx lint-staged
fi

echo "✅ Pre-commit security checks passed!"