rules_version = '2';

// Storage rules for construction management app
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to read/write their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Project files - accessible by authenticated users
    match /projects/{projectId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Sub-scoped takeoff PDFs — any authed user can upload/read. Per-doc
    // visibility is enforced by the Firestore subTakeoffs rule, not here.
    match /subTakeoffs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Site log media — any authenticated user can upload; any auth user can read
    match /site-logs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Bills (vendor invoices for AI OCR) — any authenticated user can upload + read
    // (Firestore rules gate which users can create the metadata record)
    match /bills/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Content Studio media (photos + videos for social posts)
    match /content/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Public files - readable by anyone, writable by authenticated users
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Company branding/assets - readable by all, writable by admins only
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}