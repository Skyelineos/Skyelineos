# Skyeline OS — Environment Configuration
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# Notes:
# - `VITE_*` vars are baked into the JS bundle at build time. They are visible
#   in client source — never put secrets here. Firebase web config IS public
#   (access is gated by Firestore rules), so it's fine. Stripe publishable
#   key is fine. Anything with write privileges is NOT fine.
# - Server-side secrets (Anthropic, SendGrid, Twilio, OAuth credentials,
#   etc.) live in Firebase Secret Manager and are bound to Cloud Functions
#   via `firebase functions:secrets:set NAME`. See docs/setup-runbook.md.
#
# Full provisioning runbook: docs/setup-runbook.md

# ===========================
# FIREBASE WEB CONFIG (public)
# ===========================
# Find these in: Firebase Console → Project Settings → General → Your apps → Web app config

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="skyelineos.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="skyelineos"
VITE_FIREBASE_STORAGE_BUCKET="skyelineos.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""                  # optional, Google Analytics 4

# ===========================
# FIREBASE APP CHECK (production hardening)
# ===========================
# reCAPTCHA v3 site key. Production-only — App Check is a no-op without VITE_FIREBASE_APP_CHECK_KEY set.
# See docs/setup-runbook.md §C.

VITE_FIREBASE_APP_CHECK_KEY=""
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=""           # local dev only; leave blank for committed example

# ===========================
# FRONTEND-FACING THIRD PARTIES (all public-safe keys only)
# ===========================

# Google OAuth client for the Gmail bid importer (frontend Google sign-in flow).
# Separate from the server-side Ingestion Lab OAuth client (which is in Secret Manager).
# See docs/setup-runbook.md §G.
VITE_GOOGLE_CLIENT_ID=""

# Stripe publishable key. Only needed if the payment rail is wired (selections overage fees, AI rendering paywall).
# See docs/setup-runbook.md §J and docs/decisions.md §D-007.
VITE_STRIPE_PUBLIC_KEY=""

# Sentry DSN for frontend error tracking. Public DSN is fine to ship.
# See docs/setup-runbook.md §N.
VITE_SENTRY_DSN=""

# OpenWeatherMap API key for the weather-aware Gantt.
# See docs/setup-runbook.md §O.
VITE_OWM_API_KEY=""

# ===========================
# LOCAL DEV CONVENIENCE (do not set in production builds)
# ===========================

# Auto-login a test user when set to "true". Reads localStorage `testMode` + `testUser`.
# As of D-009/D-008 this is gated behind import.meta.env.DEV server-side, so it
# only activates in `npm run dev`. Leave blank for production.
VITE_AUTO_LOGIN=""

# Use Firebase Emulators (Firestore, Auth, Functions, Storage) instead of prod.
# Requires `firebase emulators:start` running locally.
VITE_USE_FIREBASE_EMULATORS="false"

# ===========================
# WHAT IS NOT HERE (intentionally)
# ===========================
# - ANTHROPIC_API_KEY, SENDGRID_*, TWILIO_*, GOOGLE_CLIENT_SECRET, QBO_*,
#   META_*, OPENAI_API_KEY, REPLICATE_API_TOKEN, STRIPE_SECRET_KEY,
#   STRIPE_WEBHOOK_SECRET, APP_BASE_URL
#   → All Firebase Secret Manager. Run: firebase functions:secrets:set NAME
#   → See docs/setup-runbook.md §R for the master list.
#
# - DATABASE_URL, JWT_SECRET, REFRESH_SECRET, RATE_LIMIT_*, MAX_FILE_SIZE,
#   UPLOAD_DIR, SMTP_HOST/PORT/USER/PASS, AWS_*, REDIS_URL,
#   PROMETHEUS_PORT, LOG_FILE, etc.
#   → All belonged to the deleted legacy Express + Drizzle/Postgres server
#     (removed in Session 10 cleanup, commit d162314). No longer applicable.
