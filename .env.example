# Odyssey Environment Configuration
# Copy this file to .env and fill in the values

# ===========================
# REQUIRED VARIABLES
# ===========================

# Core Application Settings
NODE_ENV="development"                                    # Environment: development, production, test
PORT="5000"                                              # Server port
DATABASE_URL="postgresql://user:password@localhost:5432/odyssey"  # PostgreSQL connection string

# Authentication & Security (REQUIRED)
JWT_SECRET="your-super-secret-jwt-key-here-min-32-chars"     # JWT access token secret (32+ chars)
REFRESH_SECRET="your-super-secret-refresh-key-here-min-32-chars"  # JWT refresh token secret (32+ chars)
CORS_ORIGIN="http://localhost:3000"                         # Allowed CORS origins (comma-separated)

# ===========================
# FIREBASE CONFIGURATION
# ===========================
# Required if using Firebase features (authentication, storage, etc.)

# Firebase Web App Configuration
VITE_FIREBASE_API_KEY=""                                    # Firebase API key
VITE_FIREBASE_AUTH_DOMAIN=""                               # Firebase auth domain (project-id.firebaseapp.com)
VITE_FIREBASE_PROJECT_ID=""                                # Firebase project ID
VITE_FIREBASE_STORAGE_BUCKET=""                           # Firebase storage bucket (project-id.appspot.com)
VITE_FIREBASE_MESSAGING_SENDER_ID=""                      # Firebase messaging sender ID
VITE_FIREBASE_APP_ID=""                                    # Firebase app ID
VITE_FIREBASE_MEASUREMENT_ID=""                           # Google Analytics measurement ID (optional)

# Firebase App Check (Production Security)
VITE_FIREBASE_APP_CHECK_KEY=""                            # reCAPTCHA v3 site key for App Check
VITE_FIREBASE_APP_CHECK_DEBUG_TOKEN=""                    # Debug token for development (optional)

# Firebase Development Settings
VITE_FIREBASE_USE_EMULATORS="true"                        # Use Firebase emulators in development
VITE_FIREBASE_USE_PROD="false"                            # Force production Firebase in development

# ===========================
# SECURITY & PERFORMANCE
# ===========================

# Rate Limiting
RATE_LIMIT_MAX="100"                                       # Max requests per window per IP
RATE_LIMIT_WINDOW="900000"                                # Rate limit window in milliseconds (15 minutes)
RATE_LIMIT_AUTH_MAX="5"                                   # Max auth requests per window
RATE_LIMIT_UPLOAD_MAX="10"                               # Max upload requests per window

# File Upload Configuration
MAX_FILE_SIZE="10485760"                                  # Max file size in bytes (10MB)
UPLOAD_DIR="./uploads"                                    # Directory for file uploads
ALLOWED_FILE_TYPES="image/*,application/pdf,text/*"      # Allowed MIME types

# Database Configuration
DATABASE_MAX_CONNECTIONS="10"                             # Max database connection pool size
DATABASE_SSL="false"                                      # Enable SSL for database connection (true in production)
DATABASE_TIMEOUT="30000"                                  # Database query timeout in milliseconds

# ===========================
# LOGGING & MONITORING
# ===========================

# Logging Configuration
LOG_LEVEL="debug"                                         # Logging level: debug, info, warn, error
LOG_FILE="./logs/app.log"                                # Log file path
LOG_MAX_SIZE="10m"                                       # Max log file size before rotation
LOG_MAX_FILES="5"                                        # Max number of rotated log files

# External Monitoring (Optional)
SENTRY_DSN=""                                            # Sentry error tracking DSN
PROMETHEUS_PORT="9090"                                   # Prometheus metrics port
REDIS_URL=""                                             # Redis connection URL for caching

# ===========================
# EXTERNAL INTEGRATIONS
# ===========================

# Email Service (Optional)
SMTP_HOST=""                                             # SMTP server hostname
SMTP_PORT="587"                                          # SMTP server port
SMTP_USER=""                                             # SMTP username
SMTP_PASS=""                                             # SMTP password
SMTP_SECURE="false"                                      # Use SSL/TLS for SMTP

# Payment Processing (Optional)
STRIPE_SECRET_KEY=""                                     # Stripe secret key
STRIPE_WEBHOOK_SECRET=""                                 # Stripe webhook signing secret
STRIPE_PUBLISHABLE_KEY=""                               # Stripe publishable key (for frontend)

# SMS Notifications (Optional)
TWILIO_ACCOUNT_SID=""                                    # Twilio account SID
TWILIO_AUTH_TOKEN=""                                     # Twilio auth token
TWILIO_PHONE_NUMBER=""                                   # Twilio phone number

# Cloud Storage (Optional - alternative to local file uploads)
AWS_ACCESS_KEY_ID=""                                     # AWS access key
AWS_SECRET_ACCESS_KEY=""                                 # AWS secret key
AWS_REGION="us-east-1"                                   # AWS region
AWS_S3_BUCKET=""                                         # S3 bucket name

# ===========================
# DEVELOPMENT SETTINGS
# ===========================

# Frontend Development
VITE_API_URL="http://localhost:5000"                    # API base URL for frontend
VITE_WS_URL="ws://localhost:5000"                       # WebSocket URL for frontend
VITE_SENTRY_DSN=""                                       # Sentry DSN for frontend error tracking

# Development Tools
ENABLE_QUERY_LOGGING="false"                            # Enable SQL query logging (development only)
ENABLE_REQUEST_LOGGING="true"                           # Enable HTTP request logging
DISABLE_RATE_LIMITING="false"                           # Disable rate limiting (development only)
MOCK_EXTERNAL_APIS="false"                              # Use mock responses for external APIs

# Testing Configuration
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/odyssey_test"  # Test database URL
TEST_JWT_SECRET="test-jwt-secret-for-testing-only"      # JWT secret for testing
TEST_REFRESH_SECRET="test-refresh-secret-for-testing"   # Refresh secret for testing